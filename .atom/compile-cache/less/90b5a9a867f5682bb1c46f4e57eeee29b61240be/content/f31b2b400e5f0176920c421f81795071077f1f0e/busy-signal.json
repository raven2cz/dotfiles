{"digest":"2db07fc6f16edb7eceae50ee0a5fe44dc0356ab1","css":"busy-signal {\n  position: relative;\n  width: 16px;\n  height: 100%;\n}\nbusy-signal.idle::before,\nbusy-signal.busy::before {\n  content: '';\n  position: absolute;\n  width: 6px;\n  height: 6px;\n  top: 50%;\n  left: 5px;\n  margin-top: -3px;\n  border-radius: 50%;\n  transition: background .5s linear;\n}\nbusy-signal.idle::before {\n  background: #73c990;\n}\nbusy-signal.busy {\n  cursor: wait;\n}\nbusy-signal.busy::before {\n  background-color: #e2c08d;\n  animation: bounce 1s infinite ease-in-out;\n}\n@keyframes bounce {\n  0%,\n  100% {\n    transform: scale(1);\n  }\n  50% {\n    transform: scale(0.6);\n  }\n}\n","imports":[{"path":"static/variables/ui-variables.less","digest":"b28ed6c38c4cfce23f83a1b012a3968aa63fce4c"},{"path":"static/variables/syntax-variables.less","digest":"812c1b7883a023f768773d14294653adcdb932d7"},{"path":"node_modules/one-dark-ui/styles/ui-variables.less","digest":"f0cd54bb3195577225c676e2ba1a5f91fdd4a1ab"},{"path":"node_modules/one-dark-ui/styles/ui-variables-custom.less","digest":"912cd9b31c4db8b551f47b4d0ced938a6b62dc95"},{"path":"/home/box/.atom/packages/seti-syntax/styles/syntax-variables.less","digest":"2ca7c75b2338ffea3778cd85e3450a5f5aaf2149"},{"path":"/home/box/.atom/packages/seti-syntax/styles/colors.less","digest":"b919e43f4241528881c9a7c0c6f39b55707bc000"},{"path":"/home/box/.atom/packages/seti-syntax/styles/colors/primary.less","digest":"94e36113f44ad8e0e0f52f7e201e75df471b45ff"},{"path":"/home/box/.atom/packages/seti-syntax/styles/themes/default.less","digest":"ae125fe43a84d9d9a748f0ecadc2873d0f698db8"},{"path":"/home/box/.atom/packages/seti-syntax/styles/themes/blue.less","digest":"862fbb57f6de7e4a51003a785798daecbeeca9ff"},{"path":"/home/box/.atom/packages/seti-syntax/styles/user-theme.less","digest":"ed36563d8470ba1287116bb1a9c028bd714ed1aa"},{"path":"/home/box/.atom/packages/seti-syntax/styles/themes/blue.less","digest":"862fbb57f6de7e4a51003a785798daecbeeca